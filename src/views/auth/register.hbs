<div class="container d-flex justify-content-center align-items-center" style="min-height: 90vh; py-5">
    <div class="login-card shadow-lg">
        <div class="text-center p-4">
            <div class="display-5 text-primary mb-2">
                <i class="bi bi-person-plus-fill"></i>
            </div>
            <h1 class="h3 fw-bold text-white">Únete a Spark</h1>
            <p class="text-muted small">Crea tu cuenta y empieza a compartir tus chispas.</p>
        </div>

        <div class="card-body p-4 pt-0">
            <form action="/api/auth/register" method="POST">
                
                <div class="mb-3">
                    <label for="username" class="form-label small text-white-50">Nombre de usuario</label>
                    <div class="input-group">
                        <span class="input-group-text bg-dark border-secondary text-primary">@</span>
                        <input type="text" class="form-control bg-dark text-white border-secondary" 
                               id="username" name="username" placeholder="tu_usuario" required>
                    </div>
                </div>

                <div class="mb-3">
                    <label for="email" class="form-label small text-white-50">Correo Electrónico</label>
                    <div class="input-group">
                        <span class="input-group-text bg-dark border-secondary text-muted">
                            <i class="bi bi-envelope"></i>
                        </span>
                        <input type="email" class="form-control bg-dark text-white border-secondary" 
                               id="email" name="email" placeholder="nombre@correo.com" required>
                    </div>
                </div>

                <div class="mb-4">
                    <label for="password" class="form-label small text-white-50">Contraseña</label>
                    <div class="input-group">
                        <span class="input-group-text bg-dark border-secondary text-muted">
                            <i class="bi bi-lock"></i>
                        </span>
                        <input type="password" class="form-control bg-dark text-white border-secondary" 
                               id="password" name="password" placeholder="Mínimo 6 caracteres" required>
                    </div>
                </div>

                <div class="d-grid gap-2">
                    <button type="submit" class="btn btn-primary py-2 fw-bold rounded-pill shadow-sm">
                        Crear Cuenta Gratis
                    </button>
                </div>
            </form>

            <div class="text-center mt-4">
                <p class="text-muted small mb-0">¿Ya eres parte de Spark? 
                    <a href="/login" class="text-primary fw-bold text-decoration-none">Inicia sesión aquí</a>
                </p>
            </div>
        </div>
    </div>
</div>