{{!-- 1. Cabecera Fija --}}
<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <title>Spark - Enciende la conversación</title>
    <link rel="stylesheet" href="/style.css" />
  </head>
<div class="container">
    <h1>✨ Spark</h1>

    {{!-- 1. La caja de publicación con su clase --}}
    <section class="publish-box">
        <form action="/sparks" method="POST">
            <textarea 
                name="content" 
                id="sparkContent" 
                placeholder="¿Listo para encender nuevas ideas?" 
            ></textarea>
            
            <button type="submit">Chispa! ⚡</button>
        </form>
        {{!-- Usamos un div con clear para arreglar el float del botón --}}
        <div style="clear: both;"></div>
    </section>

    <hr />

    {{!-- 2. El contenedor del feed --}}
    <div id="feed">
        {{#each sparks}}
            <div class="spark-card">
                <p>{{this.content}}</p>
                <small>{{this.createdAt}}</small>
            </div>
        {{else}}
            <p style="text-align: center; color: #8899a6;">Aún no hay chispas. ¡Sé el primero!</p>
        {{/each}}
    </div>
</div>

  <script src="script.js"></script>

    </body>
</html>