<div class="container">
    <div class="navigation-back">
        <a href="/">&larr; Volver al inicio</a>
    </div>

    <article class="spark-detail-card">
        <div class="card-header">
            <span class="user-handle">@{{spark.username}}</span>
            <small class="timestamp">{{formatDate spark.created_at}}</small>
        </div>
        
        <div class="spark-body">
            <p>{{spark.content}}</p>
        </div>

        <div class="card-footer-actions">
            <span>🔥 {{spark.likes}} Chispazos</span>
        </div>
    </article>
</div>