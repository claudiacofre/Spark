<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-12 col-md-8 col-lg-6" style="max-width: 700px;">
            <div class="settings-card shadow bg-dark text-white border-secondary p-4">
                <h2 class="h4 fw-bold mb-4 border-bottom border-secondary pb-2">
                    <i class="bi bi-person-gear me-2 text-primary"></i>Configuración
                </h2>

                <div class="mb-5 text-center p-3 border border-secondary rounded">
                    <h5 class="small fw-bold text-uppercase text-muted mb-3">Foto de Perfil</h5>
                    
                    <div class="mb-3">
                        {{#if user.avatar}}
                           <img src="{{user.avatar}}" id="avatarPreview" class="rounded-circle" style="width: 100px; height: 100px; object-fit: cover;">
                        {{else}}
                            <div class="rounded-circle bg-secondary d-flex align-items-center justify-content-center mx-auto" style="width: 100px; height: 100px; font-size: 2rem;">✨</div>
                        {{/if}}
                    </div>

                    <form id="uploadForm">
                        <input type="file" id="fileInput" name="image" class="form-control form-control-sm bg-dark text-white border-secondary mb-2" accept="image/*">
                        <button type="submit" id="btnUpload" class="btn btn-primary btn-sm w-100 rounded-pill d-none">
                            Confirmar Subida
                        </button>
                    </form>
                    <div id="uploadMessage" class="small mt-2"></div>
                </div>

                <form action="/api/users/update" method="POST">
                    <div class="mb-3">
                        <label class="form-label small fw-bold">Nombre de usuario</label>
                        <input type="text" class="form-control bg-dark text-white border-secondary" name="username" value="{{user.username}}" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-bold">Correo electrónico</label>
                        <input type="email" class="form-control bg-dark text-white border-secondary" name="email" value="{{user.email}}" required>
                    </div>
                    <div class="mb-4">
                        <label class="form-label small fw-bold">Biografía</label>
                        <textarea class="form-control bg-dark text-white border-secondary" name="bio" rows="3">{{user.bio}}</textarea>
                    </div>
                    <button type="submit" class="btn btn-primary w-100 rounded-pill fw-bold">Guardar Cambios</button>
                </form>
            </div>
        </div>
    </div>
</div>